# Environment Configuration

# Server
PORT=3000
DOMAIN=http://localhost:3000
NODE_ENV=development

# Session
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# SMTP (Email)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Telegram Bots
USER_BOT_TOKEN=your-user-bot-token
ADMIN_BOT_TOKEN=your-admin-bot-token
SUPPORT_BOT_TOKEN=your-support-bot-token
CONTROL_BOT_TOKEN=your-control-bot-token
BOT_USERNAME=YourBot_Bot
ADMIN_IDS=123456789,987654321
CONTROL_CHAT_ID=your-control-chat-id

# Webhooks
WEBHOOK_SECRET=your-webhook-secret-key
SUPPORT_BOT_URL=http://localhost:3002
